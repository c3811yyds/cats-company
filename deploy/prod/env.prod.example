COMPOSE_PROJECT_NAME=catscompany_prod
PROD_STACK_ROOT=/srv/catscompany-prod
GHCR_REGISTRY=ghcr.io
GHCR_OWNER=replace-with-github-owner
IMAGE_TAG=replace-with-a-commit-sha

PROD_API_HOST_PORT=26061
PROD_GRPC_HOST_PORT=26062
PROD_WEB_HOST_PORT=28080

# Shadow prod should use a dedicated DB user while the legacy prod app is still online.
# Do not reuse the legacy "openchat" DB user unless traffic has already fully cut over.
OC_DB_DSN=openchat_shadow:replace-with-a-strong-db-password@tcp(host.docker.internal:3306)/openchat?parseTime=true&charset=utf8mb4
# Set to 1 only after legacy prod has been fully cut over or stopped and sharing the DB user is intentional.
ALLOW_SHARED_DB_USER=0
OC_JWT_SECRET=replace-with-a-random-jwt-secret-at-least-64-chars
