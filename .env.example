# CatsCompany Environment Configuration
# Copy this file to deploy/.env and fill in your values

# ============================================
# Database Configuration
# ============================================
MYSQL_ROOT_PASSWORD=your-secure-root-password
MYSQL_USER=openchat
MYSQL_PASSWORD=your-secure-db-password

# ============================================
# Bot Credentials
# ============================================
# Password for the default AI assistant bot
BOT_ASSISTANT_PASSWORD=your-secure-bot-password

# API key for Xiaoba bot (if using)
XIAOBA_BOT_API_KEY=

# ============================================
# LLM API Configuration
# ============================================
# OpenAI-compatible API endpoint
LLM_API_BASE=https://api.openai.com/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL=gpt-3.5-turbo

# Alternative: DeepSeek
# LLM_API_BASE=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat

# Alternative: Qwen (通义千问)
# LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-turbo

# ============================================
# Security (Production)
# ============================================
# JWT secret for token signing
JWT_SECRET=your-random-jwt-secret-at-least-32-chars

# ============================================
# Email Verification (Tencent Cloud SES)
# ============================================
TENCENTCLOUD_SECRET_ID=your-tencent-cloud-secret-id
TENCENTCLOUD_SECRET_KEY=your-tencent-cloud-secret-key
TENCENTCLOUD_REGION=ap-guangzhou
TENCENT_SES_FROM_EMAIL=noreply@mail.catsco.cc
TENCENT_SES_FROM_NAME=Cats Company
TENCENT_SES_TEMPLATE_ID=174748
TENCENT_SES_SUBJECT=Cats Company 注册验证码
# Optional. Defaults to TENCENT_SES_FROM_EMAIL when empty.
TENCENT_SES_REPLY_TO=

# ============================================
# Optional: Bot Deploy Integration
# ============================================
# Gauz Platform deploy API base URL.
# Example (same host, different Docker Compose project):
# DEPLOY_API_URL=http://host.docker.internal:8000
DEPLOY_API_URL=

# ============================================
# Advanced Reader Proxy
# ============================================
# Internal advanced-reader base URL used by Cats backend only.
# Example: http://127.0.0.1:28110
ADVANCED_READER_INTERNAL_URL=

# Optional service-to-service request signing when advanced-reader auth is enabled.
ADVANCED_READER_CLIENT_ID=
ADVANCED_READER_CLIENT_SECRET=
# ADVANCED_READER_CLIENT_SECRET_FILE=/run/secrets/advanced_reader_client_secret

# Optional overrides.
ADVANCED_READER_SIGNING_PATH=/analyze
ADVANCED_READER_INTERNAL_TIMEOUT_SECONDS=300
ADVANCED_READER_PROXY_MAX_BODY_BYTES=104857600

# Go module proxy for Docker builds.
# If your cloud server cannot reach proxy.golang.org, use:
# GOPROXY=https://goproxy.cn,direct
GOPROXY=https://proxy.golang.org,direct

# ============================================
# Optional: SSL/TLS Certificates
# ============================================
# Place your certificates in deploy/nginx/ssl/
# SSL_CERT=fullchain.pem
# SSL_KEY=privkey.pem
